# ---- Backend (Node server + Postgres) ----
# On Railway these live on the backend service; DATABASE_URL should reference
# the Postgres plugin as ${{Postgres.DATABASE_URL}}. Locally, use the DB's
# public URL (DATABASE_PUBLIC_URL) or a local Postgres.
DATABASE_URL=
AUTH_SECRET=
APP_URL=http://localhost:5173
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
RESEND_API_KEY=
INVITE_FROM_EMAIL=noreply@huddlegames.org
BGG_API_TOKEN=
UPLOAD_DIR=./uploads

# ---- Frontend (Firebase — being phased out during the Railway migration) ----
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
