{
  "rules": {
    "boards": {
      "$boardId": {
        ".read": "auth != null && data.child('members').child(auth.uid).exists()",
        ".write": "auth != null && ((!data.exists() && newData.child('members').child(auth.uid).val() === 'admin') || data.child('members').child(auth.uid).val() === true || data.child('members').child(auth.uid).val() === 'admin' || (data.child('members').child(auth.uid).val() === 'editor' && newData.child('members').val() === data.child('members').val()))",
        "memberProfiles": {
          "$memberUid": {
            ".write": "auth != null && auth.uid === $memberUid"
          }
        }
      }
    },
    "userBoards": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        "$boardId": {
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },
    "invites": {
      "$boardId": {
        ".read": "auth != null && root.child('boards').child($boardId).child('members').child(auth.uid).val() === 'admin'",
        ".write": "auth != null && root.child('boards').child($boardId).child('members').child(auth.uid).val() === 'admin'"
      }
    },
    "emailInvites": {
      "$emailKey": {
        "$boardId": {
          ".write": "auth != null && root.child('boards').child($boardId).child('members').child(auth.uid).val() === 'admin'"
        }
      }
    }
  }
}
