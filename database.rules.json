{
  "rules": {
    "boards": {
      "$boardId": {
        ".read": "auth != null && data.child('members').child(auth.uid).exists()",
        ".write": "auth != null && ((!data.exists() && newData.child('members').child(auth.uid).exists()) || data.child('members').child(auth.uid).exists())",
        "memberProfiles": {
          "$memberUid": {
            ".write": "auth != null && auth.uid === $memberUid"
          }
        }
      }
    },
    "userBoards": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        "$boardId": {
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },
    "invites": {
      "$boardId": {
        ".read": "auth != null && (root.child('boards').child($boardId).child('members').child(auth.uid).val() === 'owner' || root.child('boards').child($boardId).child('members').child(auth.uid).val() === 'admin' || root.child('boards').child($boardId).child('members').child(auth.uid).val() === 'editor')",
        ".write": "auth != null && (root.child('boards').child($boardId).child('members').child(auth.uid).val() === 'owner' || root.child('boards').child($boardId).child('members').child(auth.uid).val() === 'admin' || root.child('boards').child($boardId).child('members').child(auth.uid).val() === 'editor')"
      }
    },
    "emailInvites": {
      "$emailKey": {
        "$boardId": {
          ".write": "auth != null && (root.child('boards').child($boardId).child('members').child(auth.uid).val() === 'owner' || root.child('boards').child($boardId).child('members').child(auth.uid).val() === 'admin' || root.child('boards').child($boardId).child('members').child(auth.uid).val() === 'editor')"
        }
      }
    },
    "boardSteam": {
      "$boardId": {
        ".read": "auth != null && root.child('boards').child($boardId).child('members').child(auth.uid).exists()"
      }
    },
    "fcmTokens": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    }
  }
}
